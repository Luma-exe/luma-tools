# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Stats dashboard ────────────────────────────────────────────────────────────
# Set a password to enable the /stats dashboard. Leave blank to disable it.
STATS_PASSWORD=

# ── Paid features / billing ───────────────────────────────────────────────────
# Accounts and paid tiers will use Stripe.
SESSION_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
APP_BASE_URL=http://localhost:8080

# ── Discord OAuth (single-button signup) ───────────────────────────────────────
# Create an application at https://discord.com/developers/applications, copy
# the Client ID + Client Secret, then add this redirect URI on the OAuth2 tab:
#   https://YOUR_DOMAIN/account/oauth/discord/callback
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=

# ── Spotify Web API (for playlist/album download via YouTube proxy) ────────────
# Get these from https://developer.spotify.com/dashboard (free, takes 60 seconds).
# Without these, single Spotify tracks still work via oEmbed but playlists/albums
# will return a "credentials missing" error.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Discord ────────────────────────────────────────────────────────────────────
# Enables server-start notifications and daily usage digests to Discord.
# Leave blank to disable.
DISCORD_WEBHOOK_URL=

# ── AI providers (at least one recommended to enable AI study tools) ───────────
# Primary — llama-3.3-70b, deepseek-r1, qwen models
GROQ_API_KEY=

# Fallback providers (used automatically if Groq is unavailable)
CEREBRAS_API_KEY=
GEMINI_API_KEY=
