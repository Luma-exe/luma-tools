# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Stats dashboard ────────────────────────────────────────────────────────────
# Set a password to enable the /stats dashboard. Leave blank to disable it.
STATS_PASSWORD=

# ── Paid features / billing ───────────────────────────────────────────────────
# Accounts and paid tiers will use Stripe.
SESSION_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
APP_BASE_URL=http://localhost:8080

# ── Discord ────────────────────────────────────────────────────────────────────
# Enables server-start notifications and daily usage digests to Discord.
# Leave blank to disable.
DISCORD_WEBHOOK_URL=

# ── AI providers (at least one recommended to enable AI study tools) ───────────
# Primary — llama-3.3-70b, deepseek-r1, qwen models
GROQ_API_KEY=

# Fallback providers (used automatically if Groq is unavailable)
CEREBRAS_API_KEY=
GEMINI_API_KEY=
